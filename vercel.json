{
      "version": 2,
      "builds": [
              { "src": "index.html", "use": "@vercel/static" },
              { "src": "api/**/*.js", "use": "@vercel/node" }
      ],
      "routes": [
              { "src": "/api/(.*)", "dest": "/api/$1" },
              { "src": "/(.*)", "dest": "/index.html" }
      ],
      "env": {
              "OPENAI_API_KEY": "@openai_api_key",
              "CLAUDE_API_KEY": "@claude_api_key"
      }
}
